# Container image for the React frontend (apps/web/), running Vite's
# dev server rather than a production build — this Dockerfile is meant
# for local docker-compose use, not deployment.
FROM node:20-alpine

WORKDIR /app

COPY package.json ./
RUN npm install

COPY . .

EXPOSE 5173

# --host 0.0.0.0 so the dev server is reachable from outside the
# container (Vite binds to localhost only by default).
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
