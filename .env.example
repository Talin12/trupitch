# Copy to .env and fill in the secrets. Everything the API, worker, and
# docker-compose read from the environment is listed here.

# --- Secrets ---------------------------------------------------------------
# OpenAI key for Stage 3 LLM scoring (used only when LLM_BASE_URL is unset;
# omit to use the deterministic mock)
OPENAI_API_KEY=
# GitHub personal access token for worker repo checks (raises rate limit 60/h -> 5000/h)
GITHUB_TOKEN=
# GitHub OAuth app (callback URL: http://localhost:8000/api/auth/github/callback)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# HS256 signing key for session JWTs — required, no default (e.g. `openssl rand -hex 32`)
JWT_SECRET=

# --- Services (host-side; containers get their own values via compose) ------
# Postgres maps to host port 5433 (5432 often taken by a native Postgres on macOS)
DATABASE_URL=postgresql+asyncpg://trupitch:trupitch@localhost:5433/trupitch
REDIS_URL=redis://localhost:6379/0
FRONTEND_URL=http://localhost:5173

# --- Defaults ---------------------------------------------------------------
# Organizer used for campaigns created without an organizer_id (until organizer auth exists)
ADMIN_EMAIL=admin@trupitch.local
ADMIN_NAME=Admin User

# --- Internal admin panel (SQLAdmin, mounted at /admin) ---------------------
# Staff-only, Django-style CRUD over the raw tables. The panel stays LOCKED
# until ADMIN_PASSWORD is set — leave it empty in any environment where you
# don't want the panel reachable. ADMIN_USERNAME defaults to "admin".
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
# Signing key for the admin session cookie, kept separate from JWT_SECRET.
# Falls back to JWT_SECRET if left empty (e.g. `openssl rand -hex 32`).
ADMIN_SESSION_SECRET=

# --- LLM provider (OpenAI-compatible) ---------------------------------------
# Any OpenAI-compatible endpoint works. Examples:
#   OpenAI:       leave LLM_BASE_URL empty, set OPENAI_API_KEY, LLM_MODEL=gpt-4o-mini
#   Hugging Face: LLM_BASE_URL=https://router.huggingface.co/v1,
#                 LLM_API_KEY=hf_..., LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
# With no usable key, the worker scores with a labeled deterministic mock.
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
